# Melvin AI chatbot — Google Gemini API key (server-side only, never exposed to the client).
# Free tier: create a key at https://aistudio.google.com/apikey then:
#   - Local dev:  copy this file to .env.local and paste your key below
#   - Production: add GEMINI_API_KEY in your Vercel project's Environment Variables
GEMINI_API_KEY=
